# configuration file /etc/nginx/conf.d/hub.freshstudio.hr.conf:
server {
    listen 80;
    server_name hub.freshstudio.hr www.hub.freshstudio.hr;

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name hub.freshstudio.hr www.hub.freshstudio.hr;

    ssl_certificate /etc/letsencrypt/live/hub.freshstudio.hr/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/hub.freshstudio.hr/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;

    root /var/www/fresh-studio-hub/dist;
    index index.html;

    # Backend API na /api -> Node na portu 4000
    location /api/ {
        proxy_pass http://127.0.0.1:4100/;
        proxy_http_version 1.1;

        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Frontend (Vite build)
    location / {
        try_files $uri $uri/ /index.html;
    }
}


